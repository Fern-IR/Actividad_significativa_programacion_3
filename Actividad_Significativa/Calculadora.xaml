<Window x:Class="Actividad_Significativa.Calculadora"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calculadora - Infija a Postfija (Pilas)"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoOscuro}">

    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/Estilos.xaml"/>
    </Window.Resources>

    <!-- Tres columnas: ayuda, teclado central, salida infijapostfijaresultado -->
    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="ColorFondoOscuro"/>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.1*"/>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="1.1*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center"
                    HorizontalAlignment="Stretch" Margin="16,0,24,0">

            <TextBlock Text="Calculadora de expresiones"
                       FontFamily="Segoe UI" FontSize="24" FontWeight="Bold"
                       Foreground="{StaticResource ColorTextoClaro}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,8"/>
            <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Como funciona"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,10"/>
                    <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="{StaticResource ColorTextoAtenuado}"
                               TextWrapping="Wrap" LineHeight="20">
                        <Run Text="1."/>
                        <Run Text=" " FontWeight="Bold"/>
                        <Run Text="Se tokeniza la expresion infija."/>
                        <LineBreak/>
                        <Run Text="2."/>
                        <Run Text="Se convierte a postfija."/>
                        <LineBreak/>
                        <Run Text="3."/>
                        <Run Text="Se obtiene el resultado."/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>

        <Border Grid.Column="1" Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="20"
                Padding="0" Margin="8,18" VerticalAlignment="Center">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Display: expresion que escribe el usuario y titulo de modulo -->
                <Border Grid.Row="0" CornerRadius="20,20,0,0" Padding="24,20" Background="{StaticResource GradienteEncabezado}">
                    <StackPanel>
                        <TextBlock Text="CALCULADORA"
                                   FontFamily="Segoe UI" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoAtenuado}"/>
                        <TextBlock x:Name="TxtDisplay" Text="0"
                                   FontFamily="Segoe UI" FontSize="42" FontWeight="Bold"
                                   Foreground="{StaticResource ColorTextoClaro}" TextAlignment="Right"
                                   TextWrapping="Wrap" Margin="0,8,0,0"/>
                        <TextBlock x:Name="TxtExpresion" Text=""
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="{StaticResource ColorTextoAtenuado}" TextAlignment="Right"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <UniformGrid Grid.Row="1" Rows="1" Columns="4" Margin="12,12,12,0">
                    <Button x:Name="Btn7" Click="BotonNumerico_Click" Content="7"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn8" Click="BotonNumerico_Click" Content="8"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn9" Click="BotonNumerico_Click" Content="9"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="BtnDiv" Click="BotonOperador_Click" Content="/"
                            Style="{StaticResource EstiloBotonAzul}" Height="60" FontSize="22" Margin="4"/>
                </UniformGrid>

                <UniformGrid Grid.Row="2" Rows="1" Columns="4" Margin="12,0">
                    <Button x:Name="Btn4" Click="BotonNumerico_Click" Content="4"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn5" Click="BotonNumerico_Click" Content="5"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn6" Click="BotonNumerico_Click" Content="6"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="BtnMult" Click="BotonOperador_Click" Content="*"
                            Style="{StaticResource EstiloBotonAzul}" Height="60" FontSize="22" Margin="4"/>
                </UniformGrid>

                <UniformGrid Grid.Row="3" Rows="1" Columns="4" Margin="12,0">
                    <Button x:Name="Btn1" Click="BotonNumerico_Click" Content="1"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn2" Click="BotonNumerico_Click" Content="2"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn3" Click="BotonNumerico_Click" Content="3"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="BtnResta" Click="BotonOperador_Click" Content="-"
                            Style="{StaticResource EstiloBotonAzul}" Height="60" FontSize="22" Margin="4"/>
                </UniformGrid>

                <!-- Parentesis, cero y suma (infija completa antes de pulsar ) -->
                <UniformGrid Grid.Row="4" Rows="1" Columns="4" Margin="12,0">
                    <Button x:Name="BtnParAbierto" Click="BotonOperador_Click" Content="("
                            Style="{StaticResource EstiloBotonGris}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="BtnParCerrado" Click="BotonOperador_Click" Content=")"
                            Style="{StaticResource EstiloBotonGris}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="Btn0" Click="BotonNumerico_Click" Content="0"
                            Style="{StaticResource EstiloBotonAlgoritmo}" Height="60" FontSize="20" Margin="4"/>
                    <Button x:Name="BtnSuma" Click="BotonOperador_Click" Content="+"
                            Style="{StaticResource EstiloBotonAzul}" Height="60" FontSize="22" Margin="4"/>
                </UniformGrid>

                <Grid Grid.Row="5" Margin="12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BtnBorrarUno" Click="BtnBorrarUno_Click"
                            Content="⌫" Style="{StaticResource EstiloBotonPeligro}"
                            Height="60" FontSize="20" Margin="4"/>
                    <Button Grid.Column="1" x:Name="BtnPunto" Click="BotonNumerico_Click"
                            Content="." Style="{StaticResource EstiloBotonAlgoritmo}"
                            Height="60" FontSize="24" FontWeight="Bold" Margin="4"/>
                    <Button Grid.Column="2" Grid.ColumnSpan="2"
                            x:Name="BtnIgual" Click="BtnIgual_Click"
                            Content="=" Style="{StaticResource EstiloBotonTeal}"
                            Height="60" FontSize="28" Margin="4"/>
                </Grid>

                <Grid Grid.Row="6" Margin="12,0,12,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="BtnLimpiarTodo" Click="BtnLimpiarTodo_Click"
                            Content="Limpiar" Style="{StaticResource EstiloBotonPeligro}"
                            Height="44" FontSize="14" Margin="4"/>
                    <Button Grid.Column="1" x:Name="BtnVolver" Click="BtnVolver_Click"
                            Content="Menu" Style="{StaticResource EstiloBotonGris}"
                            Height="44" FontSize="14" Margin="4"/>
                </Grid>

            </Grid>
        </Border>

        <StackPanel Grid.Column="2" VerticalAlignment="Center"
                    HorizontalAlignment="Stretch" Margin="24,0,16,0">
            <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Expresion infija"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtExpresionMostrada" IsReadOnly="True"
                             Background="{StaticResource ColorFondoOscuro}" Foreground="{StaticResource ColorTextoClaro}"
                             FontFamily="Cascadia Code, Consolas" FontSize="16"
                             BorderThickness="0" TextWrapping="Wrap"
                             Padding="8" MinHeight="50"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Notacion postfija"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtPostfija" IsReadOnly="True"
                             Background="{StaticResource ColorFondoOscuro}" Foreground="{StaticResource ColorResaltado}"
                             FontFamily="Cascadia Code, Consolas" FontSize="16"
                             BorderThickness="0" TextWrapping="Wrap"
                             Padding="8" MinHeight="50"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="12" Padding="20">
                <StackPanel>
                    <TextBlock Text="Resultado"
                               FontFamily="Segoe UI" FontSize="13" FontWeight="Bold"
                               Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,10"/>
                    <TextBox x:Name="TxtResultadoExpr" IsReadOnly="True"
                             Background="{StaticResource ColorFondoOscuro}" Foreground="{StaticResource ColorTextoClaro}"
                             FontFamily="Cascadia Code, Consolas" FontSize="24" FontWeight="Bold"
                             BorderThickness="0" Padding="8" MinHeight="50"
                             TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</Window>
