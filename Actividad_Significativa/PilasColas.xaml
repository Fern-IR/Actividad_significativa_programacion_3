<Window x:Class="Actividad_Significativa.PilasColas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pilas y Colas - Estructuras de Datos"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoOscuro}">

    <Window.Resources>
        <ResourceDictionary Source="pack://application:,,,/Estilos.xaml"/>
    </Window.Resources>

    <!-- Izquierda: formulario; derecha: representacion visual de pila y cola -->
    <Grid Background="{StaticResource ColorFondoOscuro}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="2.95*"/>
        </Grid.ColumnDefinitions>

        <!-- Controles apilardesapilar y encolardesencolar con validaciones opcionales de capacidad -->
        <Border Grid.Column="0" Background="{StaticResource GradienteSidebar}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Titulo del modulo -->
                <StackPanel Grid.Row="0" Margin="20,30,20,20">
                    <TextBlock Text="Pilas y colas" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Scroll: muchos botones en altura limitada -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,0,20,20">
                    <StackPanel>
                        
                        <!-- Bloque LIFO: entrada, push, pop, consultas -->
                        <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Pila" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,12"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtInputPila" Grid.Column="0" Height="48" Margin="0,0,10,0" Padding="10,0"
                                             Background="{StaticResource ColorFondoOscuro}" Foreground="{StaticResource ColorTextoClaro}" BorderBrush="{StaticResource ColorBordeOscuro}" VerticalContentAlignment="Center"
                                             ToolTip="Valor para apilar"/>
                                    <Button x:Name="BtnRandomPila" Grid.Column="1" Content="Aleatorio" MinWidth="92" Height="40"
                                            Click="BtnRandomPila_Click" Style="{StaticResource EstiloBotonRandom}"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnInsertarPila" Grid.Column="0" Content="agregar" Height="38" Margin="0,0,5,0"
                                            Click="BtnInsertarPila_Click" Style="{StaticResource EstiloBotonAzul}"/>
                                    <Button x:Name="BtnQuitarPila" Grid.Column="1" Content="Eliminar" Height="38" Margin="5,0,0,0"
                                            Click="BtnQuitarPila_Click" Style="{StaticResource EstiloBotonPeligro}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnVaciaPila" Grid.Column="0" Content=" Esta Vacia?" Height="32" Margin="0,0,5,0"
                                            Click="BtnVaciaPila_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResVaciaPila" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnLlenaPila" Grid.Column="0" Content=" Esta Llena?" Height="32" Margin="0,0,5,0"
                                            Click="BtnLlenaPila_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResLlenaPila" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnCimaPila" Grid.Column="0" Content="Cima" Height="32" Margin="0,0,5,0"
                                            Click="BtnCimaPila_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResCimaPila" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Maximo" FontSize="12" Foreground="{StaticResource ColorTextoAtenuado}" VerticalAlignment="Center" Margin="0,0,10,0" HorizontalAlignment="Right"/>
                                    <TextBox x:Name="TxtResMaxPila" Grid.Column="1" Height="32" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorTextoClaro}" BorderBrush="{StaticResource ColorBordeOscuro}" FontSize="13" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>
                                
                                <Button x:Name="BtnMaxPila" Content="Aplicar Tamano Maximo" Height="32" Margin="0,0,0,10"
                                        Click="BtnMaxPila_Click" Style="{StaticResource EstiloBotonGris}"/>
                                <Button x:Name="BtnLimpiarPila" Content="Limpiar pila" Height="32"
                                        Click="BtnLimpiarPila_Click" Style="{StaticResource EstiloBotonPeligro}"/>
                            </StackPanel>
                        </Border>

                        <!-- Bloque FIFO: misma idea que la pila pero con frente distinto al final -->
                        <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="8" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Cola" FontSize="14" FontWeight="Bold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,12"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="TxtInputCola" Grid.Column="0" Height="48" Margin="0,0,10,0" Padding="10,0"
                                             Background="{StaticResource ColorFondoOscuro}" Foreground="{StaticResource ColorTextoClaro}" BorderBrush="{StaticResource ColorBordeOscuro}" VerticalContentAlignment="Center"
                                             ToolTip="Valor para encolar"/>
                                    <Button x:Name="BtnRandomCola" Grid.Column="1" Content="Aleatorio" MinWidth="92" Height="40"
                                            Click="BtnRandomCola_Click" Style="{StaticResource EstiloBotonRandom}"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="BtnInsertarCola" Grid.Column="0" Content="agregar" Height="38" Margin="0,0,5,0"
                                            Click="BtnInsertarCola_Click" Style="{StaticResource EstiloBotonTeal}"/>
                                    <Button x:Name="BtnQuitarCola" Grid.Column="1" Content="Eliminar" Height="38" Margin="5,0,0,0"
                                            Click="BtnQuitarCola_Click" Style="{StaticResource EstiloBotonPeligro}"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnVaciaCola" Grid.Column="0" Content=" Esta Vacia?" Height="32" Margin="0,0,5,0"
                                            Click="BtnVaciaCola_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResVaciaCola" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnLlenaCola" Grid.Column="0" Content=" Esta Llena?" Height="32" Margin="0,0,5,0"
                                            Click="BtnLlenaCola_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResLlenaCola" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <Button x:Name="BtnFrenteCola" Grid.Column="0" Content="Cima" Height="32" Margin="0,0,5,0"
                                            Click="BtnFrenteCola_Click" Style="{StaticResource EstiloBotonGris}"/>
                                    <TextBox x:Name="TxtResFrenteCola" Grid.Column="1" IsReadOnly="True" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorResaltado}" BorderBrush="{StaticResource ColorBordeOscuro}" FontFamily="Consolas" FontSize="12" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Maximo" FontSize="12" Foreground="{StaticResource ColorTextoAtenuado}" VerticalAlignment="Center" Margin="0,0,10,0" HorizontalAlignment="Right"/>
                                    <TextBox x:Name="TxtResMaxCola" Grid.Column="1" Height="32" Background="{StaticResource ColorFondoOscuro}" 
                                             Foreground="{StaticResource ColorTextoClaro}" BorderBrush="{StaticResource ColorBordeOscuro}" FontSize="13" Padding="5,0" VerticalContentAlignment="Center"/>
                                </Grid>
                                
                                <Button x:Name="BtnMaxCola" Content="Aplicar Tamano Maximo" Height="32" Margin="0,0,0,10"
                                        Click="BtnMaxCola_Click" Style="{StaticResource EstiloBotonGris}"/>
                                <Button x:Name="BtnLimpiarCola" Content="Limpiar cola" Height="32"
                                        Click="BtnLimpiarCola_Click" Style="{StaticResource EstiloBotonPeligro}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Volver al MainWindow -->
                <Border Grid.Row="2" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="0,1,0,0" Padding="20">
                    <Button x:Name="BtnVolver" Content="Volver al menu principal" Height="45"
                            Click="BtnVolver_Click" Style="{StaticResource EstiloBotonSidebar}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Panel principal: estado y listas que reflejan el contenido actual -->
        <Grid Grid.Column="1" Background="{StaticResource ColorFondoOscuro}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Titulo del area grafica -->
            <Border Grid.Row="0" Background="{StaticResource ColorFondoOscuroSuave}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="0,0,0,1">
                <Grid Margin="30,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Visualizacion" FontSize="22" FontWeight="SemiBold" TextAlignment="Center" Foreground="{StaticResource ColorTextoClaro}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dos columnas: pila (arribaabajo) y cola (izquierdaderecha) -->
            <Grid Grid.Row="1" Margin="30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ListBox: primer elemento tope -->
                <Border Grid.Column="0" Background="{StaticResource ColorSuperficieOscura}" CornerRadius="12" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="{StaticResource ColorAcento}" CornerRadius="11,11,0,0" Padding="15">
                            <TextBlock Text="Pila" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ColorBlanco}" HorizontalAlignment="Center"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,15">
                            <ListBox x:Name="LstVisPila" BorderThickness="0" Background="Transparent" 
                                     HorizontalContentAlignment="Center" Focusable="False" SelectionMode="Single">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ColorAcento}" CornerRadius="6" BorderBrush="{StaticResource ColorAzulClaro}" BorderThickness="1" 
                                                Padding="25,10" Margin="0,5" MinWidth="140">
                                            <TextBlock Text="{Binding}" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource ColorBlanco}" FontSize="18"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{StaticResource ColorFondoOscuro}" CornerRadius="0,0,11,11" Padding="15">
                            <TextBlock Text="Base de la pila" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ColorTextoAtenuado}" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ListBox: primer elemento frente de la cola -->
                <Border Grid.Column="2" Background="{StaticResource ColorSuperficieOscura}" CornerRadius="12" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Border Grid.Row="0" Background="{StaticResource ColorTeal}" CornerRadius="11,11,0,0" Padding="15">
                            <TextBlock Text="Cola" FontSize="16" FontWeight="Bold" Foreground="{StaticResource ColorBlanco}" HorizontalAlignment="Center"/>
                        </Border>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="15,0">
                            <ListBox x:Name="LstVisCola" BorderThickness="0" Background="Transparent" 
                                     VerticalContentAlignment="Center" Focusable="False" SelectionMode="Single">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource ColorTeal}" CornerRadius="6" BorderBrush="{StaticResource ColorTealClaro}" BorderThickness="1" 
                                                Padding="15,25" Margin="5,0" MinHeight="100" MinWidth="70">
                                            <TextBlock Text="{Binding}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource ColorBlanco}" FontSize="18"/>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="{StaticResource ColorFondoOscuro}" CornerRadius="0,0,11,11" Padding="15">
                            <Grid>
                                <TextBlock Text="Salida" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ColorTextoAtenuado}" HorizontalAlignment="Left"/>
                                <TextBlock Text="Entrada" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ColorTextoAtenuado}" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <Border Grid.Row="2" Background="{StaticResource ColorFondoOscuroSuave}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="0,1,0,0" Padding="20">
                <TextBlock x:Name="TxtStatusBar" Text="" 
                           FontFamily="Segoe UI" FontSize="13" Foreground="{StaticResource ColorTextoAtenuado}" VerticalAlignment="Center"/>
            </Border>
        </Grid>

    </Grid>
</Window>
