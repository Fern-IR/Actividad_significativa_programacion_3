 <Window x:Class="Actividad_Significativa.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Actividad_Significativa"
        mc:Ignorable="d"
        Title="Estructuras de Datos y Algoritmos"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource ColorFondoOscuro}">

    <Window.Resources>
        <!-- Recursos locales: plantilla de tarjeta y merge con Estilosxaml del proyecto -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Estilos.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="EstiloTarjetaModulo" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ColorSuperficieOscura}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextoClaro}"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="MinWidth" Value="320"/>
                <Setter Property="Height" Value="190"/>
                <Setter Property="Padding" Value="16"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" BorderBrush="{StaticResource ColorBordeOscuro}"
                                    CornerRadius="12" BorderThickness="1" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="3" Background="{StaticResource ColorAcento}" Opacity="0.65" CornerRadius="0,0,10,10"/>
                                    <Ellipse HorizontalAlignment="Right" VerticalAlignment="Top" Width="52" Height="52" Fill="{StaticResource ColorSuperficieOscuraAlt}" Opacity="0.5" Margin="0,-8,-8,0"/>
                                    <ContentPresenter/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource ColorSuperficieOscuraAlt}"/>
                                    <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource ColorAcento}"/>
                                    <Setter TargetName="bd" Property="Margin" Value="0,-1,0,1"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- Tres filas: titulo, grilla de modulos, margen inferior -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
        </Grid.RowDefinitions>

        <!-- Titulo de la aplicacion (actividad integradora) -->
        <Border Grid.Row="0" Margin="24,20,24,8" Padding="18" Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="12">
            <Grid>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Estructuras de Datos y Algoritmos" FontSize="36" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Fondo decorativo + Viewbox para que las tarjetas escalan en pantallas distintas -->
        <Grid Grid.Row="1" Margin="18,6,18,14">
            <Canvas IsHitTestVisible="False">
                <Ellipse Width="420" Height="420" Fill="{StaticResource ColorSuperficieOscuraAlt}" Opacity="0.22" Canvas.Left="-120" Canvas.Top="-60"/>
                <Ellipse Width="360" Height="360" Fill="{StaticResource ColorSuperficieOscuraAlt}" Opacity="0.18" Canvas.Right="-80" Canvas.Top="40"/>
                <Ellipse Width="280" Height="280" Fill="{StaticResource ColorSuperficieOscuraAlt}" Opacity="0.15" Canvas.Left="520" Canvas.Top="360"/>
            </Canvas>

            <!-- UniformGrid 2x4: cada boton abre un tema (lista, pilas, ordenamiento, etc) -->
            <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" VerticalAlignment="Center">
                <UniformGrid Rows="2" Columns="4" Width="1480" Height="500">
                    <Button x:Name="btnListas" Click="btnListas_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorAcento}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="🔗" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Listas enlazadas" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Gestiona inserciones, eliminaciones y busquedas en listas simples y doblemente enlazadas." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnPilasColas" Click="btnPilasColas_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorTeal}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="📚" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Pilas y colas" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Explora estructuras LIFO y FIFO con operaciones de insercion, extraccion y estado." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnOrdenamiento" Click="btnOrdenamiento_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorRandom}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="📊" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Ordenamiento" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Compara algoritmos de ordenamiento y busqueda sobre arreglos con resultados visuales." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnCalculadora" Click="btnCalculadora_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorAcento}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="🧮" FontSize="27" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Calculadora" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Convierte expresiones infijas a postfijas y evalua resultados usando pilas." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnArboles" Click="btnArboles_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorTeal}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="🌳" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Arboles binarios" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Trabaja con BST, recorridos clasicos y balanceo para analizar el rendimiento." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnGrafos" Click="btnGrafos_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorPeligro}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="🕸️" FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Grafos" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Modela vertices y aristas, y ejecuta recorridos DFS, BFS y caminos minimos." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnRecursividadCard" Click="btnRecursividad_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorAcento}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="R" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ColorTextoClaro}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Recursividad" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Practica factorial, fibonacci, suma recursiva de vectores e inversion de numeros." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <Button x:Name="btnTorreHanoiCard" Click="btnTorreHanoi_Click" Style="{StaticResource EstiloTarjetaModulo}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="54" Height="54" Background="{StaticResource ColorTeal}" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Top">
                                <TextBlock Text="H" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource ColorTextoClaro}"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                <TextBlock Text="Torre de Hanoi" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource ColorTextoClaro}" Margin="0,0,0,6"/>
                                <TextBlock Text="Visualiza la solucion recursiva con animaciones, contador de movimientos y modo paso a paso." FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource ColorTextoAtenuado}"/>
                            </StackPanel>
                        </Grid>
                    </Button>
                </UniformGrid>
            </Viewbox>
        </Grid>

        <Border Grid.Row="2" Padding="0,10"/>

    </Grid>
</Window>