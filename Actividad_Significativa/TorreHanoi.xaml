<Window x:Class="Actividad_Significativa.Torre_Hanoi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Torres de Hanoi"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{StaticResource ColorFondoOscuro}">

    <Grid Margin="20">
        <!-- Fila 0: titulo y volver; fila 1: controles + Canvas de torres -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabecera compacta con boton de retorno al menu -->
        <Border Grid.Row="0"
                Style="{StaticResource EstiloSeccion}"
                Margin="0,0,0,14"
                Padding="18,14">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Torres de Hanoi"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ColorTextoClaro}"/>
                </StackPanel>

                <Button x:Name="BtnVolver"
                        DockPanel.Dock="Right"
                        Content="Volver"
                        Style="{StaticResource EstiloBotonGris}"
                        Width="120"
                        Click="BtnVolver_Click"/>
            </DockPanel>
        </Border>

        <!-- Controles (discos, auto, paso, detener) y lienzo de dibujo procedural -->
        <Border Grid.Row="1"
                Background="{StaticResource ColorSuperficieOscura}"
                BorderBrush="{StaticResource ColorBordeOscuro}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- La solucion se precalcula por recursion; el timer o el boton paso consumen esa lista -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Cantidad de discos"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource ColorTextoClaro}"
                               Margin="0,0,10,0"/>

                    <TextBox x:Name="TxtNumeroDiscos"
                             Grid.Column="1"
                             Style="{StaticResource EstiloCajaTexto}"
                             Text="5"
                             Background="{StaticResource ColorSuperficieOscuraAlt}"
                             Foreground="{StaticResource ColorTextoClaro}"
                             BorderBrush="{StaticResource ColorBorde}"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"/>

                    <Button x:Name="BtnResolver"
                            Grid.Column="3"
                            Content="Iniciar Automatico"
                            Width="140"
                            Margin="14,0,8,0"
                            Style="{StaticResource EstiloBotonAzul}"
                            Click="BtnResolver_Click"/>

                    <Button x:Name="BtnPaso"
                            Grid.Column="4"
                            Content="Paso siguiente"
                            Width="160"
                            Margin="0,0,8,0"
                            Style="{StaticResource EstiloBotonTeal}"
                            Click="BtnPaso_Click"/>

                    <Button x:Name="BtnReiniciar"
                            Grid.Column="5"
                            Content="Reiniciar"
                            Width="130"
                            Style="{StaticResource EstiloBotonPeligro}"
                            Click="BtnReiniciar_Click"/>

                    <Button x:Name="BtnDetener"
                            Grid.Column="6"
                            Content="Detener"
                            Width="120"
                            Margin="8,0,8,0"
                            Style="{StaticResource EstiloBotonGris}"
                            Click="BtnDetener_Click"/>

                    <Button x:Name="BtnAleatorio"
                            Grid.Column="7"
                            Content="Aleatorio"
                            Width="120"
                            Style="{StaticResource EstiloBotonRandom}"
                            Click="BtnAleatorio_Click"/>
                </Grid>

                <!-- Viewbox escala el Canvas al tamano de la ventana (zoom visual sin cambiar coordenadas logicas) -->
                <Viewbox Grid.Row="1"
                         Stretch="Uniform"
                         StretchDirection="Both">
                    <Border Width="1180"
                            Height="420"
                            BorderBrush="{StaticResource ColorBordeOscuro}"
                            BorderThickness="2"
                            CornerRadius="6"
                            Background="{StaticResource ColorAreaContenido}"
                            Padding="10">
                        <Canvas x:Name="CanvasHanoi"
                                Width="1160"
                                Height="400"
                                Background="{StaticResource ColorAreaContenido}"/>
                    </Border>
                </Viewbox>

                <!-- Progreso: disco actual y movimiento i de 2^n1 -->
                <TextBlock x:Name="TxtEstado"
                           Grid.Row="2"
                           Margin="0,12,0,0"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource ColorTextoAtenuado}"
                           Text="Estado"/>
            </Grid>
        </Border>
    </Grid>
</Window>
