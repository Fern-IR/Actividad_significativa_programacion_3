<Window x:Class="Actividad_Significativa.Grafos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Grafos - Estructuras de Datos"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ColorFondoOscuro}">

    <Window.Resources>
        <!-- TextBox con Tag como placeholder; DataGrid para la matriz cuando el usuario la pide -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Estilos.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="EstiloCajaTextoPlaceholder" TargetType="TextBox">
                <Setter Property="Height" Value="40"/>
                <Setter Property="MinWidth" Value="140"/>
                <Setter Property="Padding" Value="12,0"/>
                <Setter Property="Margin" Value="0,0,8,8"/>
                <Setter Property="Background" Value="{StaticResource ColorSuperficieOscuraAlt}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextoClaro}"/>
                <Setter Property="BorderBrush" Value="{StaticResource ColorBordeOscuro}"/>
                <Setter Property="BorderThickness" Value="1.4"/>
                <Setter Property="CaretBrush" Value="{StaticResource ColorTextoClaro}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="PlaceholderText"
                                               Text="{TemplateBinding Tag}"
                                               Foreground="{StaticResource ColorTextoAtenuado}"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False"
                                               Visibility="Collapsed"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ColorAcento}"/>
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource ColorSuperficieOscura}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource ColorTextoAtenuado}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="Text" Value=""/>
                                        <Condition Property="IsKeyboardFocused" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Collapsed"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="EstiloDataGridGrafos" TargetType="DataGrid">
                <Setter Property="AutoGenerateColumns" Value="True"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="Background" Value="{StaticResource ColorSuperficieOscura}"/>
                <Setter Property="Foreground" Value="{StaticResource ColorTextoClaro}"/>
                <Setter Property="BorderBrush" Value="{StaticResource ColorBordeOscuro}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="RowBackground" Value="{StaticResource ColorSuperficieOscura}"/>
                <Setter Property="AlternatingRowBackground" Value="{StaticResource ColorSuperficieOscuraAlt}"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource ColorFondoOscuro}">
        <!-- Cabecera (formulario), lienzo (dibujo), consola (logs de algoritmos) -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <!-- Alta de vertices y aristas; botones DFS, BFS, Dijkstra y vistas matrizlista -->
        <Border Grid.Row="0"
                Margin="20,18,20,10"
                Padding="16"
                Background="{StaticResource GradienteEncabezado}"
                CornerRadius="12"
                BorderBrush="{StaticResource ColorBordeOscuro}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text=" Grafos"
                               Style="{StaticResource EstiloTituloModulo}"
                               FontSize="24"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Guia rapida: 1) Agrega vertices, 2) conecta origen-destino con peso, 3) ejecuta DFS, BFS o Dijkstra."
                               Style="{StaticResource EstiloSubtitulo}"
                               Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Nuevo vertice" Style="{StaticResource EstiloEtiqueta}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtNuevoVertice"
                                     Style="{StaticResource EstiloCajaTextoPlaceholder}"
                                     Tag=""
                                     ToolTip="Nombre del nuevo vertice"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,8,0">
                            <TextBlock Text="Nodo origen" Style="{StaticResource EstiloEtiqueta}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtNodoOrigen"
                                     Style="{StaticResource EstiloCajaTextoPlaceholder}"
                                     Tag=""
                                     ToolTip="Nodo origen"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,8,0">
                            <TextBlock Text="Nodo destino" Style="{StaticResource EstiloEtiqueta}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtNodoDestino"
                                     Style="{StaticResource EstiloCajaTextoPlaceholder}"
                                     Tag=""
                                     ToolTip="Nodo destino"/>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="3">
                            <TextBlock Text="Peso de arista" Style="{StaticResource EstiloEtiqueta}" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtPesoArista"
                                     Style="{StaticResource EstiloCajaTextoPlaceholder}"
                                     Tag=""
                                     ToolTip="Peso de arista (entero >= 0)"/>
                        </StackPanel>

                        <WrapPanel Grid.Row="1" Grid.ColumnSpan="4" Margin="0,6,0,0">
                            <Button x:Name="BtnNuevoVertice" Content="Nuevo vertice" Style="{StaticResource EstiloBotonAzul}" Margin="0,0,8,8" Click="BtnNuevoVertice_Click"/>
                            <Button x:Name="BtnAgregarLazo" Content="Agregar lazo" Style="{StaticResource EstiloBotonTeal}" Margin="0,0,8,8" Click="BtnAgregarLazo_Click"/>
                            <Button x:Name="BtnDFS" Content="DFS" Style="{StaticResource EstiloBotonAlgoritmo}" Margin="0,0,8,8" Click="BtnDFS_Click"/>
                            <Button x:Name="BtnBFS" Content="BFS" Style="{StaticResource EstiloBotonAlgoritmo}" Margin="0,0,8,8" Click="BtnBFS_Click"/>
                            <Button x:Name="BtnDijkstra" Content="Dijkstra" Style="{StaticResource EstiloBotonAlgoritmo}" Margin="0,0,8,8" Click="BtnDijkstra_Click"/>
                            <Button x:Name="BtnMatrizAdyacencia" Content="Matriz de adyacencia" Style="{StaticResource EstiloBotonGris}" Margin="0,0,8,8" Click="BtnMatrizAdyacencia_Click"/>
                            <Button x:Name="BtnListaAdyacencia" Content="Lista de adyacencia" Style="{StaticResource EstiloBotonGris}" Margin="0,0,8,8" Click="BtnListaAdyacencia_Click"/>
                            <Button x:Name="BtnSalir" Content="Salir" Style="{StaticResource EstiloBotonPeligro}" Margin="0,0,8,8" Click="BtnSalir_Click"/>
                        </WrapPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="Cantidad de vertices" Style="{StaticResource EstiloEtiqueta}" HorizontalAlignment="Center" Margin="0"/>
                            <TextBlock x:Name="TxtCantVertices" Text="0" Foreground="{StaticResource ColorAcento}" FontSize="23" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource ColorSuperficieOscura}" BorderBrush="{StaticResource ColorBordeOscuro}" BorderThickness="1" CornerRadius="10" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="Cantidad de aristas" Style="{StaticResource EstiloEtiqueta}" HorizontalAlignment="Center" Margin="0"/>
                            <TextBlock x:Name="TxtCantAristas" Text="0" Foreground="{StaticResource ColorTeal}" FontSize="23" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Canvas: aristas debajo, nodos encima; overlay centrado para matriz o lista de adyacencia -->
        <Border Grid.Row="1"
                Margin="20,0,20,10"
                Padding="12"
                Background="{StaticResource ColorSuperficieOscura}"
                BorderBrush="{StaticResource ColorBordeOscuro}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Canvas x:Name="CanvasGrafo"
                        Background="{StaticResource ColorSuperficieOscura}"
                        ClipToBounds="True"/>

                <Border x:Name="PanelRepresentacion"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="760"
                        Height="420"
                        Background="{StaticResource ColorSuperficieOscura}"
                        BorderBrush="{StaticResource ColorBordeOscuro}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock x:Name="TxtTituloPanel" Text="Representacion" Style="{StaticResource EstiloTituloPaso}" Margin="0"/>
                            <Button x:Name="BtnCerrarPanel"
                                    Content="Cerrar"
                                    Style="{StaticResource EstiloBotonPeligro}"
                                    Click="BtnCerrarPanel_Click"
                                    Width="90"
                                    HorizontalAlignment="Right"/>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <DataGrid x:Name="GridMatriz"
                                      Style="{StaticResource EstiloDataGridGrafos}"
                                      Visibility="Collapsed"/>
                            <ListBox x:Name="ListaAdyacencia"
                                     Style="{StaticResource EstiloListBox}"
                                     Visibility="Collapsed"
                                     Background="{StaticResource ColorSuperficieOscura}"
                                     Foreground="{StaticResource ColorTextoClaro}"
                                     BorderBrush="{StaticResource ColorBordeOscuro}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Texto con marca de tiempo: ideal para explicar en defensa el orden de visita o distancias -->
        <Border Grid.Row="2"
                Margin="20,0,20,16"
                Padding="12"
                Background="{StaticResource ColorConsolaFondo}"
                BorderBrush="{StaticResource ColorConsolaBorde}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="Salida de algoritmos" Style="{StaticResource EstiloEtiqueta}" Foreground="{StaticResource ColorTextoAtenuado}" Margin="0"/>
                    <TextBlock x:Name="TxtEstado"
                               Text="Listo."
                               Foreground="{StaticResource ColorExito}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </DockPanel>
                <TextBox x:Name="TxtConsola"
                         Grid.Row="1"
                         Style="{StaticResource EstiloConsolaSalida}"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontSize="14"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>